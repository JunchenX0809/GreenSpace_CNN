# Keep raw data and large artifacts out of Git
# Data directories
# - Keep the directory structure + README files in git
# - Ignore large / local / derived contents inside each subfolder
/data/raw/**
/data/interim/**
/data/cache/**
/data/processed/**
!/data/README.md
!/data/**/README.md
!/data/**/.gitkeep

# Secrets
/secrets/**
!/secrets/
!/secrets/README.md
# Local datasets
/datasets/**
!/datasets/README.md

# Models and outputs
/models/**
!/models/README.md
/outputs/**
!/outputs/README.md
.keras/

# Logs
/logs/**
!/logs/.gitkeep

# Notebooks checkpoints
**/.ipynb_checkpoints/**
/report_outputs/**
/monitoring_output/**

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
.env
.env.*
*.env
Pipfile
Pipfile.lock

# OS / Editor
.DS_Store
.vscode/
.idea/

# inference folder
predictions/
clusters/

# Presentation visuals: track images, ignore generated data tables
/presentation_visuals_only/eval_ordinal/*.csv
/presentation_visuals_only/eval_binary/*.csv

# Claude agent memory (local only, not for version control)
/memory/

/skills/coding_conventions.md
# Local label-method notes (versioned drafts; not tracked)
/skills/Labels_Processing_Method_v*.md
/.cursor
.claude/
